{
  "name": "portfolio-presence",
  "version": "0.1.0",
  "description": "Privacy-first presence snapshots for portfolio sites.",
  "type": "module",
  "license": "MIT",
  "author": "Devesh Sangwan",
  "homepage": "https://deveshsangwan.github.io/portfolio-presence/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deveshsangwan/portfolio-presence.git"
  },
  "bugs": {
    "url": "https://github.com/deveshsangwan/portfolio-presence/issues"
  },
  "keywords": [
    "portfolio",
    "presence",
    "github",
    "lastfm",
    "nextjs"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && node scripts/mark-react-client.mjs",
    "check": "pnpm typecheck && pnpm test:unit && pnpm build && pnpm publint && pnpm test:integration && pnpm test:examples && pnpm docs:build",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "publint": "publint",
    "test": "pnpm test:unit",
    "test:examples": "pnpm --dir examples/next-basic build",
    "test:integration": "vitest run test/integration",
    "test:unit": "vitest run test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.3.0 || >=19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "next": "^16.2.9",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8"
  }
}
