{
  "name": "portfolio-presence",
  "version": "0.1.0",
  "description": "Privacy-first presence snapshots for portfolio sites.",
  "type": "module",
  "license": "MIT",
  "author": "Devesh Sangwan",
  "sideEffects": false,
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && node scripts/mark-react-client.mjs",
    "check": "pnpm typecheck && pnpm test && pnpm build && pnpm publint",
    "publint": "publint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.3.0 || >=19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
